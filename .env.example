# Postgres — can be the same server/database as QGen-HE; FS_GEN uses its own fsgen_* tables.
DATABASE_URL=postgresql://user:password@localhost:5432/qgen

# At least one LLM key is required. Anthropic is preferred when both are set.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Optional overrides
ANTHROPIC_MODEL=claude-sonnet-4-6
OPENAI_MODEL=gpt-5.4
# LLM_PROVIDER=anthropic   # force a provider when both keys are set
LOG_LEVEL=INFO

# Optional: LangSmith cost/token tracking (one trace per question, rolled up per stage).
# Off unless LANGSMITH_TRACING=true. Get a key at https://smith.langchain.com.
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=fs_gen
